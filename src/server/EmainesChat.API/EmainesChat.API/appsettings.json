{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/users",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/users/*/picture",
        "Period": "1h",
        "Limit": 20
      }
    ]
  }
}
